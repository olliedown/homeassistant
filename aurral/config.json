{
  "name": "Aurral",
  "slug": "aurral",
  "description": "Aurral Home Assistant Add-on",
  "version": "latest",
  "url": "https://github.com/olliedown/homeassistant",
  "arch": ["aarch64", "amd64", "armv7"],
  "codenotary": "aurral",
  "init": false,

  "startup": "services",
  "boot": "auto",
  "ports": {
    "3001/tcp": 3001
  },

  "ports_description": {
    "3001/tcp": "Web interface"
  },

  "webui": "[PROTO:ssl]://[HOST]:[PORT:3001]",

  "command": [
    "/bin/sh",
    "/run.sh"
  ]
}
